MPESA_PASSKEY=your_passkey_here
MPESA_CALLBACK_URL=https://your-domain.com/payments/mpesa/callback
MPESA_BASE_URL=https://sandbox.safaricom.co.ke

# Airtel Money (developers.airtel.africa)
